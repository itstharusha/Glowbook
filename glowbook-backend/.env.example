# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from: Atlas Dashboard → Database → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/glowbook?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRE=7d

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get these from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
