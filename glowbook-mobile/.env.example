# ── Backend API ───────────────────────────��─────────────────────────────��─────
# Development: use your local IP so the device can reach it (not localhost)
# Production: your Render / Railway URL, e.g. https://glowbook-api.onrender.com
EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:5000

# ── Google OAuth ───────────────────────────────────────────────��──────────────
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# Use "Web application" type for Expo Go / EAS builds
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_REDIRECT_URL=https://auth.expo.io/@your-expo-username/glowbook

# ── Apple Sign In ───────────────────────────���────────────────────────────────��
# Found in: Apple Developer → Membership → Team ID
APPLE_TEAM_ID=XXXXXXXXXX
